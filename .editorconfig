root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,js,jsx,ts,tsx,json,yml,yaml,md,css,html,xml,sql}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.ps1]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
